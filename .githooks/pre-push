#!/bin/sh
set -eu

allowed_local_ref="refs/heads/public-main"
allowed_remote_ref="refs/heads/main"
blocked=0

while read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$local_ref" != "$allowed_local_ref" ] || [ "$remote_ref" != "$allowed_remote_ref" ]; then
    echo "KMD PUSH POLICY: blocked $local_ref -> $remote_ref" >&2
    echo "Only local branch 'public-main' may be pushed, and only as remote 'main'." >&2
    blocked=1
  fi
done

if [ "$blocked" -ne 0 ]; then
  echo "Switch/update the public snapshot branch, then run:" >&2
  echo "  git push origin public-main:main" >&2
  exit 1
fi

exit 0
